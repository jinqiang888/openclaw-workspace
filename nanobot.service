[Unit]
Description=Nanobot - OpenClaw 智能维修系统
After=network.target

[Service]
Type=simple
User=admin
WorkingDirectory=/home/admin/.openclaw/workspace
ExecStart=/home/admin/.openclaw/workspace/nanobot-venv/bin/python /home/admin/.openclaw/workspace/nanobot-core.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target